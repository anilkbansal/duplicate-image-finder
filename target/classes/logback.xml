<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Console appender with coloured output.
        Pattern:  HH:mm:ss [LEVEL] message
        Colours:  INFO=white, WARN=yellow, ERROR=red, DEBUG=cyan
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{HH:mm:ss} %highlight(%-5level) %cyan([%thread]) %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Rolling file appender – writes full logs to duplicate-finder.log -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>duplicate-finder.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>duplicate-finder.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress noisy POI / xmlbeans / log4j-over-slf4j internal logs -->
    <logger name="org.apache.poi"         level="WARN"/>
    <logger name="org.apache.xmlbeans"    level="WARN"/>
    <logger name="com.zaxxer"             level="WARN"/>

    <!-- Swing UI log console – receives events when the GUI is running -->
    <appender name="SWING" class="com.mph.duplicate.SwingLogAppender"/>

    <!-- Root logger: INFO to console + file + Swing UI -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="SWING"/>
    </root>

</configuration>

